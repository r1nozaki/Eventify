{
  "info": {
    "name": "Eventify API",
    "description": "Eventify backend API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "registrationId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth/Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/auth/register",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"demoUser\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Auth/Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/auth/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"Password123!\"\n}"
        }
      }
    },
    {
      "name": "Auth/Refresh",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/auth/refresh",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
        }
      }
    },
    {
      "name": "Events/GetAll",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/events?pageNumber=1&pageSize=10&sortBy=date&sortOrder=asc"
      }
    },
    {
      "name": "Registrations/Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/registrations/events/{{eventId}}"
      }
    },
    {
      "name": "Registrations/My",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/registrations/me?pageNumber=1&pageSize=10"
      }
    },
    {
      "name": "Admin/Registrations",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessToken}}"
          }
        ],
        "url": "{{baseUrl}}/api/registrations?pageNumber=1&pageSize=10&status=Pending"
      }
    },
    {
      "name": "Health/Liveness",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health"
      }
    },
    {
      "name": "Health/Readiness",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/health/ready"
      }
    }
  ]
}
